interface ParseSourceLocation {
    offset: number;
    line: number;
    col: number;
}
interface ParseSourceSpan {
    start: ParseSourceLocation;
    end: ParseSourceLocation;
}
interface HtmlAttribute {
    name: string;
    value: string;
    rawSource: string;
    sourceSpan: ParseSourceSpan;
    nameSpan?: ParseSourceSpan;
    valueSpan?: ParseSourceSpan;
}
type HtmlNode = HtmlElement | HtmlText | HtmlComment | HtmlBlock | HtmlExpansion;
interface HtmlElement {
    type: 'element';
    name: string;
    attrs: HtmlAttribute[];
    children: HtmlNode[];
    sourceSpan: ParseSourceSpan;
    startSourceSpan: ParseSourceSpan;
    endSourceSpan: ParseSourceSpan | null;
}
interface HtmlText {
    type: 'text';
    value: string;
    sourceSpan: ParseSourceSpan;
}
interface HtmlComment {
    type: 'comment';
    value: string | null;
    sourceSpan: ParseSourceSpan;
}
interface HtmlBlock {
    type: 'block';
    name: string;
    children: HtmlNode[];
    sourceSpan: ParseSourceSpan;
    startSourceSpan: ParseSourceSpan;
    endSourceSpan: ParseSourceSpan | null;
}
interface HtmlExpansion {
    type: 'expansion';
    sourceSpan: ParseSourceSpan;
}
interface RootNode {
    type: 'root';
    nodes: HtmlNode[];
    originalText: string;
    hasErrors?: boolean;
}
type AttributeCategory = 'ref' | 'structural' | 'twoWay' | 'input' | 'output' | 'animation' | 'static' | 'boolean';
interface FormatOptions {
    printWidth: number;
    tabWidth: number;
    angularAttributeSort: boolean;
    angularAttributeOrder: AttributeCategory[];
}

declare function parseAngularHtml(text: string): RootNode;
declare const parsers: {
    'angular-attributes': {
        parse: typeof parseAngularHtml;
        astFormat: string;
        locStart: (node: any) => any;
        locEnd: (node: any) => any;
    };
};

declare const printers: {
    'angular-attributes-ast': {
        print(path: any, options: FormatOptions & {
            originalText: string;
        }, _print: any): string;
    };
};

declare const options: {
    angularAttributeSort: {
        type: "boolean";
        category: "Angular";
        default: boolean;
        description: string;
    };
    angularAttributeOrder: {
        type: "string";
        category: "Angular";
        array: boolean;
        default: any;
        description: string;
    };
};

declare const _default: {
    parsers: {
        'angular-attributes': {
            parse: typeof parseAngularHtml;
            astFormat: string;
            locStart: (node: any) => any;
            locEnd: (node: any) => any;
        };
    };
    printers: {
        'angular-attributes-ast': {
            print(path: any, options: FormatOptions & {
                originalText: string;
            }, _print: any): string;
        };
    };
    options: {
        angularAttributeSort: {
            type: "boolean";
            category: "Angular";
            default: boolean;
            description: string;
        };
        angularAttributeOrder: {
            type: "string";
            category: "Angular";
            array: boolean;
            default: any;
            description: string;
        };
    };
};

export { _default as default, options, parsers, printers };
